<file path="frontend/src/storage.ts">
 1: import { User, FinanceAccount, Category, Transaction, Currency } from "./types";
 2: import { defaultAccounts, defaultCategories, defaultTransactions } from "./initialData";
 3: 
 4: const STORAGE_KEYS = {
 5:   USER: "ft_user",
 6:   ACCOUNTS: "ft_accounts",
 7:   CATEGORIES: "ft_categories",
 8:   TRANSACTIONS: "ft_transactions",
 9: };
10: 
11: export function initializeStorage() {
12:   const currentUser = getStoredUser();
13: 
14: 
15:   if (!currentUser) {
16:     if (!localStorage.getItem(STORAGE_KEYS.ACCOUNTS)) {
17:       localStorage.setItem(STORAGE_KEYS.ACCOUNTS, JSON.stringify(defaultAccounts));
18:     }
19:     if (!localStorage.getItem(STORAGE_KEYS.CATEGORIES)) {
20:       localStorage.setItem(STORAGE_KEYS.CATEGORIES, JSON.stringify(defaultCategories));
21:     }
22:     if (!localStorage.getItem(STORAGE_KEYS.TRANSACTIONS)) {
23:       localStorage.setItem(STORAGE_KEYS.TRANSACTIONS, JSON.stringify(defaultTransactions));
24:     }
25:   }
26: 
27: }
28: 
29: export function getStoredUser(): User | null {
30:   const userStr = localStorage.getItem(STORAGE_KEYS.USER);
31:   return userStr ? JSON.parse(userStr) : null;
32: }
33: 
34: export function setStoredUser(user: User | null): void {
35:   if (user) {
36:     localStorage.setItem(STORAGE_KEYS.USER, JSON.stringify(user));
37:   } else {
38:     localStorage.removeItem(STORAGE_KEYS.USER);
39:   }
40: }
41: 
42: export function getStoredAccounts(): FinanceAccount[] {
43:   const accountsStr = localStorage.getItem(STORAGE_KEYS.ACCOUNTS);
44:   return accountsStr ? JSON.parse(accountsStr) : defaultAccounts;
45: }
46: 
47: export function setStoredAccounts(accounts: FinanceAccount[]): void {
48:   localStorage.setItem(STORAGE_KEYS.ACCOUNTS, JSON.stringify(accounts));
49: }
50: 
51: export function getStoredCategories(): Category[] {
52:   const categoriesStr = localStorage.getItem(STORAGE_KEYS.CATEGORIES);
53:   return categoriesStr ? JSON.parse(categoriesStr) : defaultCategories;
54: }
55: 
56: export function setStoredCategories(categories: Category[]): void {
57:   localStorage.setItem(STORAGE_KEYS.CATEGORIES, JSON.stringify(categories));
58: }
59: 
60: export function getStoredTransactions(): Transaction[] {
61:   const transactionsStr = localStorage.getItem(STORAGE_KEYS.TRANSACTIONS);
62:   return transactionsStr ? JSON.parse(transactionsStr) : defaultTransactions;
63: }
64: 
65: export function setStoredTransactions(transactions: Transaction[]): void {
66:   localStorage.setItem(STORAGE_KEYS.TRANSACTIONS, JSON.stringify(transactions));
67: }
68: 
69: 
70: export const EXCHANGE_RATES: Record<Currency, number> = {
71:   [Currency.UAH]: 1.0,
72:   [Currency.USD]: 41.2,
73:   [Currency.EUR]: 44.5,
74: };
75: 
76: export function convertToCurrency(amount: number, from: Currency, to: Currency): number {
77:   if (from === to) return amount;
78:   const uahAmount = amount * EXCHANGE_RATES[from];
79:   return uahAmount / EXCHANGE_RATES[to];
80: }
81: 
82: 
83: export function clearAllUserData(): void {
84:   localStorage.removeItem(STORAGE_KEYS.USER);
85:   localStorage.removeItem(STORAGE_KEYS.ACCOUNTS);
86:   localStorage.removeItem(STORAGE_KEYS.CATEGORIES);
87:   localStorage.removeItem(STORAGE_KEYS.TRANSACTIONS);
88:   localStorage.removeItem("access_token");
89: }
