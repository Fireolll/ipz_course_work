 3: 
 4: from dal import analytics_dal
 5: from core.enums import TypeOfCashFlow, Currency
 6: from schemas.analytics_schema import BalanceReportResponse, CategoryStat
 7: 
 8: async def generate_balance_report(db: AsyncSession, user_id: int, user_currency: Currency) -> BalanceReportResponse:
 9: 
10: 
11: 
12:     total_income = await analytics_dal.get_total_cashflow_by_type(db, user_id, TypeOfCashFlow.income)
13:     total_expense = await analytics_dal.get_total_cashflow_by_type(db, user_id, TypeOfCashFlow.expense)
14: 
15: 
16:     net_balance = total_income - total_expense
17: 
18: 
19:     expenses_raw = await analytics_dal.get_expenses_grouped_by_category(db, user_id)
20: 
21: 
22:     expenses_by_category = []
23:     for row in expenses_raw:
24:         cat_name = row.category_name
25:         cat_total = row.total_amount
26: 
27:         percentage = 0.0
28:         if total_expense > 0:
29: 
30:             percentage = round(float((cat_total / total_expense) * 100), 1)
31: 
32:         expenses_by_category.append(
33:             CategoryStat(
34:                 category_name=cat_name,
35:                 total_amount=cat_total,
36:                 percentage=percentage
37:             )
38:         )
39: 
40: 
41:     return BalanceReportResponse(
42:         total_income=total_income,
43:         total_expense=total_expense,
44:         net_balance=net_balance,
45:         currency=user_currency,
46:         expenses_by_category=expenses_by_category
47:     )
</file>

