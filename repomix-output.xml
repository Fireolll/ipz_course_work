23: def create_access_token(data: dict, expires_delta: timedelta | None = None) -> str:
24: 
25: 
26:     to_encode = data.copy()
27: 
28: 
29:     if expires_delta:
30:         expire = datetime.now(timezone.utc) + expires_delta
31:     else:
32:         expire = datetime.now(timezone.utc) + timedelta(minutes=settings.ACCESS_TOKEN_EXPIRE_MINUTES)
33: 
34: 
35:     to_encode.update({"exp": expire})
36: 
37: 
38:     encoded_jwt = jwt.encode(
39:         to_encode,
40:         settings.SECRET_KEY,
41:         algorithm=settings.ALGORITHM
42:     )
43: 
44:     return encoded_jwt
45: 
46: oauth2_scheme = OAuth2PasswordBearer(tokenUrl="auth/login")
47: 
48: async def get_current_user(
49:     token: str = Depends(oauth2_scheme),
50:     db: AsyncSession = Depends(get_db)
51: ):
52: 
53:     credentials_exception = HTTPException(
54:         status_code=status.HTTP_401_UNAUTHORIZED,
55:         detail="Не вдалося перевірити облікові дані",
56:         headers={"WWW-Authenticate": "Bearer"},
57:     )
58:     try:
59:         payload = jwt.decode(token, settings.SECRET_KEY, algorithms=[settings.ALGORITHM])
60:         user_id_str: str = payload.get("sub")
61:         if user_id_str is None:
62:             raise credentials_exception
63:         user_id = int(user_id_str)
64:     except JWTError:
65:         raise credentials_exception
66: 
67: 
68:     user = await get_user_by_id(db, user_id)
69:     if user is None:
70:         raise credentials_exception
71: 
72:     return user
