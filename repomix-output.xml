28: 
29:     # Шукаємо користувача за email
30:     user = await user_dal.get_user_by_email(db, email)
31:     if not user:
32:         raise HTTPException(
33:             status_code=status.HTTP_401_UNAUTHORIZED,
34:             detail="Невірний email або пароль"
35:         )
36: 
37:     # Звіряємо пароль із хешем у базі
38:     if not verify_password(password, user.password_hash): #type: ignore
39:         raise HTTPException(
40:             status_code=status.HTTP_401_UNAUTHORIZED,
41:             detail="Невірний email або пароль"
42:         )
43: 
44:     # генерація токену для авторизованого користувача
45:     access_token = create_access_token(data={"sub": str(user.user_id)})
46: 
