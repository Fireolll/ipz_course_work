  1: import { User, FinanceAccount, Category, Transaction, Currency, TypeOfCashFlow } from "../types";
  2: import { convertToCurrency } from "../storage";
  3: import { categoryColors, defaultColors } from "../initialData";
  4: import { TrendingUp, TrendingDown, ArrowUpRight, ArrowDownRight, Award, Scale, Percent } from "lucide-react";
  5: import { motion } from "motion/react";
  6: 
  7: interface AnalyticsProps {
  8:   user: User;
  9:   accounts: FinanceAccount[];
 10:   categories: Category[];
 11:   transactions: Transaction[];
 12: }
 13: 
 14: export default function AnalyticsTab({ user, accounts, categories, transactions }: AnalyticsProps) {
 15: 
 16:   let totalIncome = 0;
 17:   let totalExpense = 0;
 18: 
 19:   transactions.forEach(tx => {
 20:     const acc = accounts.find(a => a.fa_id === tx.fa_id);
 21:     if (!acc) return;
 22:     const cat = categories.find(c => c.category_id === tx.category_id);
 23:     if (!cat) return;
 24: 
 25:     const amountInHome = convertToCurrency(tx.amount, acc.currency, user.currency);
 26:     if (cat.type_of_cash_flow === TypeOfCashFlow.INCOME) {
 27:       totalIncome += amountInHome;
 28:     } else {
 29:       totalExpense += amountInHome;
 30:     }
 31:   });
 32: 
 33:   const netBalance = totalIncome - totalExpense;
 34:   const isProfit = netBalance >= 0;
 35: 
 36: 
 37:   const expenseMap: Record<number, { name: string; sum: number }> = {};
 38:   let absoluteExpenses = 0;
 39: 
 40:   transactions.forEach(tx => {
 41:     const cat = categories.find(c => c.category_id === tx.category_id);
 42:     if (!cat || cat.type_of_cash_flow !== TypeOfCashFlow.EXPENSE) return;
 43:     const acc = accounts.find(a => a.fa_id === tx.fa_id);
 44:     if (!acc) return;
 45: 
 46:     const amountInHome = convertToCurrency(tx.amount, acc.currency, user.currency);
 47:     absoluteExpenses += amountInHome;
 48: 
 49:     if (expenseMap[tx.category_id]) {
 50:       expenseMap[tx.category_id].sum += amountInHome;
 51:     } else {
 52:       expenseMap[tx.category_id] = {
 53:         name: cat.category_name,
 54:         sum: amountInHome,
 55:       };
 56:     }
 57:   });
 58: 
 59:   const expenseStats = Object.keys(expenseMap).map(key => {
 60:     const catId = Number(key);
 61:     const item = expenseMap[catId];
 62:     return {
 63:       category_id: catId,
 64:       category_name: item.name,
 65:       total_amount: item.sum,
 66:       percentage: absoluteExpenses > 0 ? (item.sum / absoluteExpenses) * 100 : 0,
 67:     };
 68:   }).sort((a, b) => b.total_amount - a.total_amount);
 69: 
