 4: function getAuthToken(): string | null {
 5:   const token = localStorage.getItem("access_token");
 6:   return token ? token : null;
 7: }
 8: 
 9: 
10: async function apiRequest<T>(
11:   endpoint: string,
12:   method: "GET" | "POST" | "PUT" | "DELETE" = "GET",
13:   body?: any
14: ): Promise<T> {
15:   const headers: HeadersInit = {
16:     "Content-Type": "application/json",
17:   };
18: 
19:   const token = getAuthToken();
20:   if (token) {
21:     headers["Authorization"] = `Bearer ${token}`;
22:   }
23: 
24:   const response = await fetch(`${API_BASE_URL}${endpoint}`, {
25:     method,
26:     headers,
27:     body: body ? JSON.stringify(body) : undefined,
28:   });
29: 
30:   if (!response.ok) {
31:     const errorData = await response.json().catch(() => ({}));
32:     throw new Error(errorData.detail || `Помилка: ${response.status}`);
33:   }
34: 
35:   return response.json();
36: }
37: 
38: 
39: async function loginRequest(credentials: { email: string; password: string }) {
40:   const formData = new URLSearchParams();
41:   formData.append("username", credentials.email);
42:   formData.append("password", credentials.password);
43: 
44:   const response = await fetch(`${API_BASE_URL}/auth/login`, {
45:     method: "POST",
46:     headers: {
47:       "Content-Type": "application/x-www-form-urlencoded",
48:     },
49:     body: formData,
50:   });
51: 
52:   if (!response.ok) {
53:     throw new Error("Невірний логін або пароль");
54:   }
55: 
56:   return response.json();
57: }
